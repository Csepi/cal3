{
  "name": "primecalendar-docs-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "docusaurus start --port 3001",
    "build": "node node_modules/@docusaurus/core/bin/docusaurus.mjs build . --out-dir build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "check:links": "node ../scripts/docs/check-links.cjs",
    "check:metadata": "node ../scripts/docs/check-metadata.cjs",
    "check": "npm run check:links && npm run check:metadata"
  },
  "dependencies": {
    "@docusaurus/core": "^3.7.0",
    "@docusaurus/preset-classic": "^3.7.0",
    "@easyops-cn/docusaurus-search-local": "^0.48.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
