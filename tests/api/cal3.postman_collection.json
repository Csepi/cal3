          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health status is < 500', function () {",
                  "  pm.expect(pm.response.code).to.be.below(500);",
                  "});"
                ]
              }
            }
          ]
        }
