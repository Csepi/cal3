    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-PrimeCal-Client",
                "value": "mobile-native"
              },
              {
                "key": "x-device-fingerprint",
                "value": "postman-device"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register returns created or conflict', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-PrimeCal-Client",
                "value": "mobile-native"
              },
              {
                "key": "x-device-fingerprint",
                "value": "postman-device"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login status is successful', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('auth payload has access token', function () {",
                  "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (json.access_token) { pm.environment.set('accessToken', json.access_token); }",
                  "if (json.refresh_token) { pm.environment.set('refreshToken', json.refresh_token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/auth/profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "X-PrimeCal-Client",
                "value": "mobile-native"
              },
              {
                "key": "x-device-fingerprint",
                "value": "postman-device"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "profile"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('profile is available after login', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('profile has identity fields', function () {",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('username');",
                  "  pm.expect(body).to.have.property('email');",
                  "});"
                ]
              }
            }
          ]
        },
